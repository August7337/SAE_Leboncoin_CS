# =============================================================================
# .env.example — Variables d'environnement pour Docker Compose
# Copier vers .env et remplir les valeurs réelles :
#   cp .env.example .env
# =============================================================================

# ─── Base de données PostgreSQL ──────────────────────────────────────────────
DB_NAME=LeboncoinDB
DB_USER=leboncoin_user
DB_PASS=ChangeMeStrong!2024

# ─── Port exposé de l'API sur l'hôte ─────────────────────────────────────────
API_PORT=8080

# ─── JWT — OBLIGATOIRE ────────────────────────────────────────────────────────
# Au minimum 32 caractères aléatoires
JWT_SECRET_KEY=CHANGE_ME_very_long_random_secret_at_least_32_chars
JWT_ISSUER=LeboncoinAPI
JWT_AUDIENCE=LeboncoinVueApp

# ─── Environnement ASP.NET Core ───────────────────────────────────────────────
# Production | Development | Staging
ASPNETCORE_ENVIRONMENT=Production

# ─── Cloudinary (optionnel — upload d'images) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe (optionnel — paiements) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
